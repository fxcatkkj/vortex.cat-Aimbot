RunService.Heartbeat:Connect(function()
    local Character = LocalPlayer.Character
    if not Character then return end
    local RootPart = Character:FindFirstChild("HumanoidRootPart")
    if not RootPart then return end
    
    local CameraDirection = Workspace.CurrentCamera.CFrame
    
    if Features.FootFly then
        local FlyBV = RootPart:FindFirstChild("FxcatFlyBV")
        if not FlyBV then
            FlyBV = Instance.new("BodyVelocity")
            FlyBV.Name = "FxcatFlyBV"
            FlyBV.MaxForce = Vector3.new(40000, 40000, 40000)
            FlyBV.Parent = RootPart
        end
        
        local MoveVector = Vector3.new(
            (UserInputService:IsKeyDown(Enum.KeyCode.D) and 1 or 0) - (UserInputService:IsKeyDown(Enum.KeyCode.A) and 1 or 0),
            (UserInputService:IsKeyDown(Enum.KeyCode.Space) and 1 or 0) - (UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) and 1 or 0),
            (UserInputService:IsKeyDown(Enum.KeyCode.S) and 1 or 0) - (UserInputService:IsKeyDown(Enum.KeyCode.W) and 1 or 0)
        ) * Settings.FootFlySpeed
        
        FlyBV.Velocity = CameraDirection:VectorToWorldSpace(MoveVector)
    else
        local FlyBV = RootPart:FindFirstChild("FxcatFlyBV")
        if FlyBV then FlyBV:Destroy() end
    end
    
    local Seat = Character:FindFirstChildOfClass("SeatWeld") or Character:FindFirstChildOfClass("VehicleSeat")
    if Seat then
        local Vehicle = Seat.Parent
        local VehicleRoot = Vehicle.PrimaryPart or Vehicle:FindFirstChild("HumanoidRootPart")
        
        if VehicleRoot then
            if Features.VehicleFling then
                for _, Part in pairs(Workspace:GetPartBoundsInRadius(VehicleRoot.Position, 30)) do
                    if Part.Parent ~= Vehicle and Part.Parent ~= Character then
                        CreateFling(Part)
                    end
                end
            end
            
            if Features.CarFly then
                local CarBV = VehicleRoot:FindFirstChild("FxcatCarFly")
                if not CarBV then
                    CarBV = Instance.new("BodyVelocity")
                    CarBV.Name = "FxcatCarFly"
                    CarBV.MaxForce = Vector3.new(50000, 50000, 50000)
                    CarBV.Parent = VehicleRoot
                end
                
                local CarMoveVector = Vector3.new(
                    (UserInputService:IsKeyDown(Enum.KeyCode.D) and 1 or 0) - (UserInputService:IsKeyDown(Enum.KeyCode.A) and 1 or 0),
                    (UserInputService:IsKeyDown(Enum.KeyCode.Space) and 1 or 0) - (UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) and 1 or 0),
                    (UserInputService:IsKeyDown(Enum.KeyCode.S) and 1 or 0) - (UserInputService:IsKeyDown(Enum.KeyCode.W) and 1 or 0)
                ) * Settings.CarFlySpeed
                
                CarBV.Velocity = CameraDirection:VectorToWorldSpace(CarMoveVector)
            else
                local CarBV = VehicleRoot:FindFirstChild("FxcatCarFly")
                if CarBV then CarBV:Destroy() end
            end
        end
    end
end)

