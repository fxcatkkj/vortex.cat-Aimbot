local function getBestTarget()
    local bestTarget, bestDist = nil, aimbotSettings.distance
    local count = 0
    
    for _, player in pairs(game.Players:GetPlayers()) do
        if player ~= lp and player.Character and player.Character:FindFirstChild("Head") then
            local head = player.Character.Head
            local screenPos, onScreen = camera:WorldToViewportPoint(head.Position)
            local dist = (Vector2.new(screenPos.X, screenPos.Y) - Vector2.new(camera.ViewportSize.X/2, camera.ViewportSize.Y/2)).Magnitude
            
            if onScreen and dist < aimbotSettings.fov and (head.Position - camera.CFrame.Position).Magnitude < aimbotSettings.distance then
                count = count + 1
                if count <= aimbotSettings.maxTargets then
                    bestTarget = player
                    bestDist = dist
                end
            end
        end
    end
    return bestTarget
end

rs.RenderStepped:Connect(function()
    if aimbotSettings.showFov then
        fovCircle.Visible = true
        fovCircle.Radius = aimbotSettings.fov
        fovCircle.Position = Vector2.new(uis:GetMouseLocation().X, uis:GetMouseLocation().Y)
    else
        fovCircle.Visible = false
    end
    
    if features.aimbot then
        local target = getBestTarget()
        if target and target.Character and target.Character:FindFirstChild("Head") then
            local targetPos = target.Character.Head.Position
            local currentCFrame = camera.CFrame
            camera.CFrame = currentCFrame:lerp(CFrame.lookAt(currentCFrame.Position, targetPos), aimbotSettings.smoothness)
        end
    end
end)

local function applyFling(part)
    if part and part.Parent ~= lp.Character then
        local bv = Instance.new("BodyVelocity")
        bv.MaxForce = Vector3.new(1e6, 1e6, 1e6)
        bv.Velocity = Vector3.new(
            math.random(-2e4, 2e4),
            math.random(2e4, 5e4),
            math.random(-2e4, 2e4)
        )
        bv.Parent = part
        
        game:GetService("Debris"):AddItem(bv, 0.3)
    end
end

