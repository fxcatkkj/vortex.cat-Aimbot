local vehicleConnection
rs.Heartbeat:Connect(function()
    local char = lp.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    
    local seat = char:FindFirstChild("SeatWeld") or char:FindFirstChildOfClass("VehicleSeat")
    if seat then
        local vehicle = seat.Parent
        local vehicleRoot = vehicle.PrimaryPart or vehicle:FindFirstChild("HumanoidRootPart")
        
        if vehicleRoot then
            if features.vehicleFling then
                for _, part in pairs(workspace:GetPartBoundsInRadius(vehicleRoot.Position, 25)) do
                    if part.Parent ~= vehicle and part.Parent ~= char then
                        applyFling(part)
                    end
                end
            end
            
            if features.carFly then
                local cam = workspace.CurrentCamera
                local moveDir = Vector3.new(
                    (uis:IsKeyDown(Enum.KeyCode.D) and 1 or 0) - (uis:IsKeyDown(Enum.KeyCode.A) and 1 or 0),
                    (uis:IsKeyDown(Enum.KeyCode.Space) and 1 or 0) - (uis:IsKeyDown(Enum.KeyCode.LeftShift) and 1 or 0),
                    (uis:IsKeyDown(Enum.KeyCode.S) and 1 or 0) - (uis:IsKeyDown(Enum.KeyCode.W) and 1 or 0)
                ) * flySpeeds.car
                
                local bv = vehicleRoot:FindFirstChild("CarFlyBV")
                if not bv then
                    bv = Instance.new("BodyVelocity")
                    bv.Name = "CarFlyBV"
                    bv.MaxForce = Vector3.new(4e4, 4e4, 4e4)
                    bv.Parent = vehicleRoot
                end
                bv.Velocity = cam.CFrame:VectorToWorldSpace(moveDir)
            else
                local bv = vehicleRoot:FindFirstChild("CarFlyBV")
                if bv then bv:Destroy() end
            end
        end
    end
    
    if features.footFly and root then
        local bv = root:FindFirstChild("FootFlyBV")
        if not bv then
            bv = Instance.new("BodyVelocity")
            bv.Name = "FootFlyBV"
            bv.MaxForce = Vector3.new(4e4, 4e4, 4e4)
            bv.Parent = root
        end
        
        local cam = workspace.CurrentCamera
        local moveDir = Vector3.new(
            (uis:IsKeyDown(Enum.KeyCode.D) and 1 or 0) - (uis:IsKeyDown(Enum.KeyCode.A) and 1 or 0),
            (uis:IsKeyDown(Enum.KeyCode.Space) and 1 or 0) - (uis:IsKeyDown(Enum.KeyCode.LeftShift) and 1 or 0),
            (uis:IsKeyDown(Enum.KeyCode.S) and 1 or 0) - (uis:IsKeyDown(Enum.KeyCode.W) and 1 or 0)
        ) * flySpeeds.foot
        
        bv.Velocity = cam.CFrame:VectorToWorldSpace(moveDir)
    else
        local bv = root and root:FindFirstChild("FootFlyBV")
        if bv then bv:Destroy() end
    end
end)

