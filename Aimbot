local mt = getrawmetatable(game)
local oldnc = mt.__namecall
local oldidx = mt.__index
local oldnewidx = mt.__newindex
setreadonly(mt, false)

mt.__namecall = newcclosure(function(self, ...)
    local args = {...}
    local method = getnamecallmethod()
    
    -- Block HttpService, TeleportService, ReplicatedStorage logs
    if method == "FireServer" and (tostring(self):find("Http") or tostring(self):find("Log") or tostring(self):find("Report")) then
        return wait(math.huge)
    end
    
    local blacklist = {"kick", "ban", "report", "flag", "detect"}
    for _, word in pairs(blacklist) do
        if tostring(self):lower():find(word) or method:lower():find(word) then
            return
        end
    end
    
    return oldnc(self, ...)
end)

mt.__index = newcclosure(function(self, key)
    return oldidx(self, key)
end)

mt.__newindex = newcclosure(function(self, key, value)
    return oldnewidx(self, key, value)
end)

setreadonly(mt, true)

